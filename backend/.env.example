# Express backend configuration. Copy to `.env` (gitignored) for local dev and
# set the same keys in the cranl app environment for production.

PORT=4000
CORS_ORIGIN=http://localhost:3000

# Public origin of the deployed app — used to build StreamPay redirect URLs.
PUBLIC_BASE_URL=http://localhost:3000

# StreamPay (streampay.sa) API key pair — see https://app.streampay.sa/settings/api-keys
STREAM_API_KEY=your-streampay-api-key
STREAM_API_SECRET=your-streampay-api-secret
STREAM_API_BASE=https://stream-app-service.streampay.sa

# Secret of the StreamPay webhook (Settings → Webhooks) used to verify signatures.
STREAM_WEBHOOK_SECRET=your-webhook-secret

# Supabase project URL + SECRET (service) key. The secret key bypasses RLS and
# must never reach the browser.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-secret-key

# Signed download URL lifetime in seconds (default 3 hours).
SIGNED_URL_TTL_SECONDS=10800
